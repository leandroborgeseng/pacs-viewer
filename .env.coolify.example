# Copie para o Coolify (Environment Variables do recurso Docker Compose)
# ou para um arquivo `.env` na raiz ao testar localmente:
#   cp .env.coolify.example .env
#
# Guia: docs/coolify.md

# --- PostgreSQL (serviço db) ---
POSTGRES_USER=portal
POSTGRES_PASSWORD=altere-senha-forte-do-banco
POSTGRES_DB=portal

# --- URLs públicas (HTTPS, após configurar domínios no Coolify) ---
# Portal (serviço web) — sem barra no fim
WEB_ORIGIN=https://portal.seudominio.com
# API (serviço api) — com /api no fim
NEXT_PUBLIC_API_URL=https://api.seudominio.com/api
NEXT_PUBLIC_OHIF_BASE_PATH=/ohif

# --- API (obrigatório) ---
JWT_SECRET=altere-para-string-longa-aleatoria-openssl-rand-hex-32
JWT_EXPIRES_SEC=28800

# PACS — URL DICOMweb que o container `api` consegue alcançar na rede
# (Orthanc remoto, VPN, ou http://orthanc:8042/dicom-web se usar profile local-pacs)
ORTHANC_DICOMWEB_ROOT=https://pacs.seudominio.com/dicom-web
ORTHANC_USERNAME=
ORTHANC_PASSWORD=

# UID de estudo real no PACS (opcional; usado só se SKIP_DB_SEED=0 e seed rodar)
SEED_STUDY_INSTANCE_UID=

# 1 = não reaplicar contas demo a cada deploy (recomendado em produção)
SKIP_DB_SEED=1

# Atrás do proxy Traefik do Coolify
TRUST_PROXY_HOPS=1
# 0 = não aceitar origens *.railway.app (deploy self-hosted)
CORS_ALLOW_RAILWAY_PUBLIC=0
