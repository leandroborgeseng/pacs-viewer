DATABASE_URL="postgresql://portal:portal@localhost:5432/portal"
JWT_SECRET="altere-para-uma-string-longa-aleatoria"
# Opcional — selo HMAC dos laudos PDF (recomendado em produção separado do JWT). Se vazio, usa JWT_SECRET.
# LAUDO_SEAL_SECRET="outra-string-longa-só-para-laudos"
# Segundos (300 … 604800). Fora do intervalo é ajustado no arranque. Predef.: ~8 h.
JWT_EXPIRES_SEC="28800"
# --- Segurança / login ---
# Limitação própria de `POST /api/auth/login` (por IP, após Trust Proxy quando definido).
# Predef.: 20 tentativas por janela. Global da API permanece mais alto (vários outros endpoints).
# AUTH_LOGIN_THROTTLE_LIMIT="20"
# Janela em ms (entre 1000 e 3_600_000). Predef.: 60000 (1 min).
# AUTH_LOGIN_THROTTLE_TTL_MS="60000"
# Nº de hops de proxy em frente ao Express — define `trust proxy`; necessário para `req.ip` e throttle
# corretos atrás do Railway/nginx (ex.: 1).
# TRUST_PROXY_HOPS="1"
WEB_ORIGIN="http://localhost:3000"
# Opcional — "1" regista cada pedido proxy e quando a reescrita de JSON foi aplicada (ruidoso).
# DICOMWEB_PROXY_DEBUG="1"
# --- PACS / Orthanc ---
# Pode configurar IP, porta, utilizador e URL do portal em Administração → Integração (PACS)
# (tabela `integration_settings`). As variáveis abaixo são fallback quando o host na BD está vazio.
# `WEB_ORIGIN` acima: URL público do portal (Next) — combinada na API com Integração quando definida na BD,
# para reescrever links DICOMweb do Orthanc e para CORS (`/bb-api/dicomweb` no OHIF).
ORTHANC_DICOMWEB_ROOT="http://localhost:8042/dicom-web"
# Base HTTP do Orthanc para REST (pesquisa `/tools/find`, upload `POST /instances`). Se vazio, usa o URL de DICOMweb sem o sufixo `/dicom-web`.
# ORTHANC_HTTP_ROOT="http://localhost:8042"
# Exemplo Orthanc remoto (teste): "http://189.90.139.222:8042/dicom-web"
ORTHANC_USERNAME=""
ORTHANC_PASSWORD=""
# Número da série DICOM gerada para cada laudo PDF (modality DOC). Predef.: 999.
# LAUDO_SERIES_NUMBER="999"
# Tag Manufacturer (0008,0070) nos objectos Encapsulated PDF.
# LAUDO_DICOM_MANUFACTURER="Nome da instituição"
PORT="3001"
SEED_STUDY_INSTANCE_UID=""

# TTL (ms) para cache em memória do catálogo QIDO+portal por utilizador JWT (`GET /studies/me` e `/studies/me/summary`).
# 0 desactiva cache. Predefinição sem variável: 45000 (~45 s).
# STUDIES_CATALOG_CACHE_MS="45000"
# Estudos onde o QIDO não traz texto em (0008,1030) podem usar `StudyDescription` de `MainDicomTags`
# via REST Orthanc (`GET /studies/{id}`), como na interface Web. Limite máximo de UIDs a completar por refresh.
# 0 desliga o fallback. Predef.: 500.
# STUDIES_REST_STUDY_DESC_BACKFILL_MAX="500"
# TTL (ms) para cache em memória da lista de StudyInstanceUID permitidos ao utilizador (proxy DICOMweb / OHIF).
# Reduz carga na BD com muitos pedidos encadeados. 0 desactiva. Predef.: 25000.
# ACCESS_ALLOWLIST_CACHE_MS="25000"
# Lista separada por vírgulas — modalidades de série no QIDO (00080060) tratadas como documento encapsulado (laudo PDF, etc.).
# Predef.: DOC,OT. Ex.: STUDIES_PACS_DOC_MODALITIES="DOC,OT"
# STUDIES_PACS_DOC_MODALITIES=""
