DATABASE_URL="postgresql://portal:portal@localhost:5432/portal"
JWT_SECRET="altere-para-uma-string-longa-aleatoria"
# Opcional — selo HMAC dos laudos PDF (recomendado em produção separado do JWT). Se vazio, usa JWT_SECRET.
# LAUDO_SEAL_SECRET="outra-string-longa-só-para-laudos"
# Segundos (300 … 604800). Fora do intervalo é ajustado na inicialização. Padrão: ~8 h.
JWT_EXPIRES_SEC="28800"
# --- Segurança / login ---
# Limitação própria de `POST /api/auth/login` (por IP, após Trust Proxy quando definido).
# Padrão: 20 tentativas por janela. O limite global da API continua mais alto (outros endpoints).
# AUTH_LOGIN_THROTTLE_LIMIT="20"
# Janela em ms (entre 1000 e 3_600_000). Padrão: 60000 (1 min).
# AUTH_LOGIN_THROTTLE_TTL_MS="60000"
# Nº de hops de proxy na frente do Express — define `trust proxy`; necessário para `req.ip` e throttle
# corretos atrás do Railway/nginx (ex.: 1).
# TRUST_PROXY_HOPS="1"
WEB_ORIGIN="http://localhost:3000"
# Opcional — "1" registra cada pedido proxy e quando a reescrita de JSON foi aplicada (ruidoso).
# DICOMWEB_PROXY_DEBUG="1"
# --- PACS / Orthanc ---
# É possível configurar IP, porta, usuário e URL do portal em Administração → Integração (PACS)
# (tabela `integration_settings`). As variáveis abaixo são fallback quando o host no banco está vazio.
# `WEB_ORIGIN` acima: URL pública do portal (Next) — combinada na API com Integração quando definida no banco,
# para reescrever links DICOMweb do Orthanc e para CORS (`/bb-api/dicomweb` no OHIF).
ORTHANC_DICOMWEB_ROOT="http://localhost:8042/dicom-web"
# Base HTTP do Orthanc para REST (pesquisa `/tools/find`, upload `POST /instances`). Se vazio, usa o URL do DICOMweb sem o sufixo `/dicom-web`.
# ORTHANC_HTTP_ROOT="http://localhost:8042"
# Exemplo Orthanc remoto (teste): "http://189.90.139.222:8042/dicom-web"
ORTHANC_USERNAME=""
ORTHANC_PASSWORD=""
# Número da série DICOM gerada para cada laudo PDF (modalidade DOC). Padrão: 999.
# LAUDO_SERIES_NUMBER="999"
# Tag Manufacturer (0008,0070) nos objetos Encapsulated PDF.
# LAUDO_DICOM_MANUFACTURER="Nome da instituição"
PORT="3001"
SEED_STUDY_INSTANCE_UID=""

# TTL (ms) para cache em memória do catálogo QIDO+portal por usuário JWT (`GET /studies/me` e `/studies/me/summary`).
# 0 desativa o cache. Se a variável não existir, o padrão é 45000 (~45 s).
# STUDIES_CATALOG_CACHE_MS="45000"
# Estudos em que o QIDO não traz texto em (0008,1030) podem usar `StudyDescription` de `MainDicomTags`
# via REST Orthanc (`GET /studies/{id}`), como na interface web. Limite máximo de UIDs completados por atualização.
# 0 desliga o fallback. Padrão: 500.
# STUDIES_REST_STUDY_DESC_BACKFILL_MAX="500"
# TTL (ms) para cache em memória da lista de StudyInstanceUID permitidos ao usuário (proxy DICOMweb / OHIF).
# Reduz carga no banco com muitos pedidos encadeados. 0 desativa. Padrão: 25000.
# ACCESS_ALLOWLIST_CACHE_MS="25000"
# Lista separada por vírgulas — modalidades de série no QIDO (00080060) tratadas como documento encapsulado (laudo PDF, etc.).
# Padrão: DOC,OT. Ex.: STUDIES_PACS_DOC_MODALITIES="DOC,OT"
# STUDIES_PACS_DOC_MODALITIES=""
