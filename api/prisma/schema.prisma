generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEDICO
  PACIENTE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patientProfile Patient?         @relation("PatientAccount")
  permissions    StudyPermission[]
  auditLogs      AuditLog[]

  @@map("users")
}

model Patient {
  id                  String    @id @default(uuid())
  userId              String?   @unique
  medicalRecordNumber String    @unique
  fullName            String
  birthDate           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user    User?   @relation("PatientAccount", fields: [userId], references: [id], onDelete: SetNull)
  studies Study[]

  @@map("patients")
}

model Study {
  id               String   @id @default(uuid())
  patientId        String
  studyInstanceUID String   @unique
  studyDescription String?
  studyDate        String?
  accessionNumber  String?
  modality         String?
  /// PDF ou página de resultado clínico (URL https). Ligado ao estudo pela mesma BD.
  reportUrl        String?  @db.Text @map("report_url")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  patient     Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  permissions StudyPermission[]

  @@map("studies")
}

model StudyPermission {
  id        String   @id @default(uuid())
  userId    String
  studyId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  study Study @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@unique([userId, studyId])
  @@map("permissions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  resource  String?
  ip        String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("audit_logs")
}

/// Configuração única da ligação ao PACS / portal público (UI admin). Fallback: variáveis de ambiente.
model IntegrationSettings {
  id                  String   @id @default("default")
  orthancUseTls       Boolean  @default(false) @map("orthanc_use_tls")
  /// IP ou hostname do Orthanc/PACS alcançável **pelo servidor da API**. Se vazio, usa ORTHANC_DICOMWEB_ROOT no .env.
  orthancHost         String?  @map("orthanc_host")
  orthancPort         Int      @default(8042) @map("orthanc_port")
  /// Caminho público até ao plugin DICOMweb (Orthanc típ.: /dicom-web).
  orthancDicomWebPath String   @default("/dicom-web") @map("orthanc_dicom_web_path")
  orthancUsername     String?  @map("orthanc_username")
  orthancPassword     String?  @map("orthanc_password") @db.Text
  /// URL pública exacta do portal (Next.js) para reescrita de URLs no JSON DICOM OHIF — ex.: https://portal.exemplo.pt
  webOriginPublic     String?  @map("web_origin_public") @db.Text
  laudoManufacturer   String?  @map("laudo_manufacturer")
  laudoSeriesNumber   String?  @map("laudo_series_number")
  dicomProxyDebug     Boolean  @default(false) @map("dicom_proxy_debug")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("integration_settings")
}

/// Selo sintético (HMAC) para verificar registo institucional do laudo; não é assinatura qualificada.
model ReportLaudoSeal {
  id                 String   @id @default(uuid())
  verifyCode         String   @unique @map("verify_code") @db.VarChar(48)
  studyInstanceUid   String   @map("study_instance_uid")
  sopInstanceUid     String   @map("sop_instance_uid")
  issuerUserId       String   @map("issuer_user_id")
  issuerEmail        String   @map("issuer_email")
  canonicalPayload   String   @map("canonical_payload") @db.Text
  sealMacHex         String   @map("seal_mac_hex") @db.VarChar(64)
  pdfBinarySha256Hex String   @map("pdf_binary_sha256_hex") @db.VarChar(64)
  orthancInstanceId  String?  @map("orthanc_instance_id")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([studyInstanceUid])
  @@map("report_laudo_seals")
}
