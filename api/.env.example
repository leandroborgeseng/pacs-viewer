DATABASE_URL="postgresql://portal:portal@localhost:5432/portal"
JWT_SECRET="altere-para-uma-string-longa-aleatoria"
# Segundos (300 … 604800). Fora do intervalo é ajustado no arranque. Predef.: ~8 h.
JWT_EXPIRES_SEC="28800"
WEB_ORIGIN="http://localhost:3000"
# URL público do **portal** (Next). Usado para reescrever links DICOMweb do Orthanc no proxy,
# para o OHIF carregar imagens via /bb-api/dicomweb (evita CORS em URLs absolutas do PACS).
ORTHANC_DICOMWEB_ROOT="http://localhost:8042/dicom-web"
# Exemplo Orthanc remoto (teste): "http://189.90.139.222:8042/dicom-web"
ORTHANC_USERNAME=""
ORTHANC_PASSWORD=""
PORT="3001"
